# Copy to .env and fill in. The .env file must NOT be committed (see .gitignore).
# These two are the public Supabase client keys (safe to ship in the browser
# bundle; access is bounded by Row Level Security). Set the same values in your
# host's Environment Variables (e.g. Vercel) so production builds get them too.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Server-side secrets (SUPABASE_SERVICE_ROLE_KEY, etc.) are NEVER placed here —
# they live only in the Supabase Edge Functions secrets / dashboard.
